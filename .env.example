# =====================================================
# 사주 사이트 보일러플레이트 - 환경변수
# =====================================================
# 모든 값을 채우면 동작합니다. 각 값을 얻는 방법은 README.md 참고.

# ─── Site ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────
# https://supabase.com → 프로젝트 생성 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ─── 토스페이먼츠 ────────────────────────────────────
# https://developers.tosspayments.com → 내 상점 → API 키
# 아래는 토스 공식 docs 공개 테스트 키 — 그대로 두면 즉시 테스트 결제 가능
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# ─── 만세력 API (간이) ───────────────────────────────
# 자체 만세력 API가 있다면 여기에 (어댑터는 src/lib/saju/manseryeok.ts)
# 비워두면 mock 데이터를 반환하므로 데모 모드로 동작합니다.
MANSERYEOK_API_URL=
MANSERYEOK_API_KEY=

# ─── 사주 풀 분석 API (luckyloveme) ─────────────────
# 운세위키 사주 명식표 API. 키 발급: https://luckyloveme.com/api-service
# 가이드: ./운세위키_API_가이드.md
# 어댑터: src/lib/saju/saju-api.ts / 라우트: /api/generate-manseryeok
# 헤더: X-SAJU-BOOK-API-KEY + User-Agent: SajuBookClient/1.0 (어댑터가 자동 처리)
# 미설정 시 /api/generate-manseryeok 은 503 을 반환합니다.
SAJU_API_URL=https://luckyloveme.com/api/saju-full-analysis
SAJU_API_KEY=

# ─── LLM ─────────────────────────────────────────────
# LLM_PROVIDER: openai | anthropic | gemini (하나만 채우면 됩니다)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── 이메일 발송 (Resend) ────────────────────────────
# https://resend.com → API Keys → 발급
# 미설정 시 결과지 이메일 발송은 조용히 스킵됩니다 (기능 자체는 안 막힘)
RESEND_API_KEY=
# 도메인 인증(Resend → Domains) 전에는 onboarding@resend.dev 사용 가능
RESEND_FROM_EMAIL=명리공방 <onboarding@resend.dev>

# ─── 어드민 ──────────────────────────────────────────
# /admin 진입 비밀번호. 본인이 임의 문자열로 설정하세요. 비워두면 어드민 비활성화.
# 예: ADMIN_PASSWORD=hanna-secret-2026
ADMIN_PASSWORD=
